# DocuMind_AI backend configuration

# Providers: cloud (groq + gemini) is deploy-friendly; ollama is free & local
LLM_PROVIDER=groq
EMBED_PROVIDER=gemini

# Groq (cloud LLM — generous free tier). Get a key: https://console.groq.com
GROQ_API_KEY=your-groq-api-key
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# Google Gemini (cloud embeddings). Get a key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_EMBED_MODEL=models/gemini-embedding-001

# Ollama (local option — set LLM_PROVIDER=ollama and EMBED_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Embedding dimension — must match the embedder (gemini=3072, ollama nomic=768)
EMBED_DIMENSION=3072

# Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=documind
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# CORS (frontend origins) — JSON array; add your Vercel URL for production
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# RAG parameters
CHUNK_SIZE=3500
CHUNK_OVERLAP=300
RETRIEVAL_K=4
TEMPERATURE=0.3

# Uploads
MAX_UPLOAD_MB=25
